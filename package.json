{
  "name": "gsoc-modular-lsp",
  "displayName": "GSoC Modular LSP",
  "version": "1.0.0",
  "engines": {
    "vscode": "^1.75.0"
  },
  "main": "./extension.js",
  "activationEvents": [
    "onLanguage:plaintext"
  ],
  "contributes": {
    "languages": [
      {
        "id": "plaintext",
        "extensions": [".txt"]
      }
    ],
    "semanticTokenScopes": [
      {
        "language": "plaintext",
        "scopes": {
          "keyword": ["keyword.control.fortran"],
          "function": ["entity.name.function"]
        }
      }
    ]
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "languages": [{
    "id": "fortran",
    "extensions": [".f90", ".txt"],
    "aliases": ["Fortran"]
  }]
}